# OpenClawMaster — Environment Variables Template
# Copy this file to ~/.openclaw/.env and fill in real values.
# NEVER commit .env to git.

# ── Core AI Providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
NVIDIA_NIM_API_KEY=           # NIM-specific key for integrate.api.nvidia.com
OPENAI_API_KEY=               # Optional — currently using OAuth Codex for Elon (gpt-5.4)
OPENROUTER_API_KEY=           # Optional — OpenRouter fallback routing

# ── Z.AI (ZhipuAI / GLM) ───────────────────────────────────────────────────────
ZAI_API_KEY=                  # Required by Sentinel-RT (glm-5 via api.z.ai)
                              # Canonical name. Z_AI_API_KEY is accepted as fallback.

# ── xAI (Grok) ─────────────────────────────────────────────────────────────────
XAI_API_KEY=                  # Optional — xAI/Grok models

# ── Perplexity ─────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=           # Required by Sagan (sonar-reasoning-pro) + web search plugin

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_API_KEY=               # Optional — local Ollama instance auth token

# ── Channels ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # Required: heartbeat, key health alerts, Milo DMs
DISCORD_BOT_TOKEN=            # Required: DFB delivery via Zuck → #dfb channel

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                 # Required: GitHub CLI skill, repo sync

# ── Firecrawl ──────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=            # Required by Sagan/Neo for DFB research chain

# ── Gateway ────────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=       # Shared WS secret — must match all clients on first connect
                              # (auth.mode=none means loopback-only; device pairing handles auth)
OPENCLAW_GATEWAY_PORT=18789
