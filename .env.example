# Command Center — Environment Variables Template
# Copy this file to ~/.openclaw/.env and fill in real values.
# NEVER commit .env to git.

# ── Core AI Providers ──────────────────────────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_NIM_API_KEY=           # NIM-specific key for integrate.api.nvidia.com (Milo, Elon, Themis, Cerberus)
OPENAI_API_KEY=               # ChatGPT Plus — OAuth Codex for Neo (gpt-5.4), Elon escalation, Themis/Cerberus escalation
OPENROUTER_API_KEY=           # Optional — OpenRouter fallback routing

# ── Z.AI (ZhipuAI / GLM) ───────────────────────────────────────────────────────
ZAI_API_KEY=                  # Required by Jonny (glm-5 via api.z.ai), Elon/Sagan supplementary
                              # Canonical name. Z_AI_API_KEY is accepted as fallback.

# ── xAI (Grok) ─────────────────────────────────────────────────────────────────
XAI_API_KEY=                  # Optional — xAI/Grok models

# ── Perplexity Pro ─────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=           # Required by Sagan (sonar-reasoning-pro), Pulse (sonar-pro web-grounded)

# ── Ollama Pro ─────────────────────────────────────────────────────────────────
OLLAMA_API_KEY=               # Ollama Pro — 3 concurrent cloud slots (gpt-oss:120b, minimax-m2-7 overflow)

# ── Composio MCP ───────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=             # Composio MCP — 500+ app integrations (GitHub, Google Workspace, Slack, Discord, Vercel)

# ── PaperClip Gateway ──────────────────────────────────────────────────────────
PAPERCLIP_OPENCLAW_TOKEN=     # OpenClaw gateway adapter bearer token (from PaperClip board)

# ── Channels ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # Required: heartbeat, key health alerts, Milo DMs
DISCORD_BOT_TOKEN=            # Required: DFB delivery via Zuck → #dfb channel

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                 # Required: GitHub CLI skill, repo sync (also covered by Composio)

# ── Firecrawl ──────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=            # Required by Sagan/Neo for DFB research chain

# ── Gateway ────────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=       # Shared WS secret — must match all clients on first connect
                              # (auth.mode=none means loopback-only; device pairing handles auth)
OPENCLAW_GATEWAY_PORT=18789

# ── Future: Microsoft MAI via Azure (not yet active) ───────────────────────────
# AZURE_OPENAI_API_KEY=       # MAI models: Transcribe-1, Voice-1, Image-2
# AZURE_OPENAI_ENDPOINT=      # https://<endpoint>.openai.azure.com
